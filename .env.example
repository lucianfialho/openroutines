# OpenRoutines Configuration

# Provider (Kimi Coding — Anthropic-compatible API)
# Get your key at: https://www.kimi.com/code/console
KIMI_API_KEY=sk-your-kimi-code-key
KIMI_MODEL=kimi-coding/k2p5

# GitHub
GITHUB_TOKEN=ghp-your-token
GITHUB_REPO=owner/repo
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Persistence (optional — defaults to in-memory)
# DATABASE_URL=postgresql://openroutines:openroutines@localhost:5432/openroutines

# Queue (optional — defaults to in-memory)
# REDIS_URL=redis://localhost:6379

# Server
PORT=3000
