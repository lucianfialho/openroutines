# === OpenRoutines Environment ===

# LLM Provider (Kimi K2.6 via Moonshot API)
KIMI_API_KEY=sk-...
KIMI_MODEL=moonshot-v1-128k

# GitHub Connector & Webhook
GITHUB_TOKEN=ghp_...
GITHUB_REPO=owner/repo
GITHUB_WEBHOOK_SECRET=supersecreto123

# Persistence (Neon serverless PostgreSQL for Vercel)
# Get yours at: https://neon.tech
DATABASE_URL=postgresql://user:pass@host.neon.tech/db?sslmode=require

# Optional: Redis for BullMQ queue (not used in Vercel serverless)
# REDIS_URL=redis://localhost:6379

# Local dev only
PORT=3000
ROUTINES_DIR=./routines
SKILLS_DIR=./.gates/skills
