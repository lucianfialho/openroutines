{
  "name": "openroutines",
  "version": "0.1.0",
  "description": "Open-source, self-hosted automation platform for engineering workflows. Bring your own model.",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "vercel:dev": "vercel dev",
    "vercel:build": "vercel build",
    "vercel:generate": "tsx scripts/generate-vercel-json.ts"
  },
  "dependencies": {
    "@hugeicons/react": "^1.1.6",
    "@moonshot-ai/kimi-agent-sdk": "^0.1.8",
    "@neondatabase/serverless": "^1.1.0",
    "@visual-json/core": "^0.4.0",
    "@visual-json/yaml": "^0.4.0",
    "bullmq": "^5.0.0",
    "dotenv": "^17.4.2",
    "effect": "^4.0.0-beta.74",
    "express": "^4.19.0",
    "ioredis": "^5.3.0",
    "node-cron": "^3.0.3",
    "openai": "^4.77.0",
    "pg": "^8.11.0",
    "yaml": "^2.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vercel/node": "^5.8.4",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vercel": "^54.4.1",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
