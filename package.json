{
  "name": "openroutines",
  "version": "0.1.0",
  "description": "Open-source, self-hosted automation platform for engineering workflows. Bring your own model.",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "effect": "^3.0.0",
    "bullmq": "^5.0.0",
    "ioredis": "^5.3.0",
    "pg": "^8.11.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0",
    "openai": "^4.77.0",
    "express": "^4.19.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.0",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "vitest": "^2.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
